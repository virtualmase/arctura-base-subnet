# arctura-base-subnet environment configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ── Base Chain ───────────────────────────────────────────
# Coinbase public RPC (free, rate-limited)
BASE_RPC_URL=https://mainnet.base.org

# Base Sepolia testnet RPC
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: Coinbase Node (higher rate limits, requires account)
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Bittensor ────────────────────────────────────────────
# Network: "local" | "test" | "finney"
BT_NETWORK=test

# Subnet UID (set after registration)
BT_NETUID=1

# Wallet names
BT_OWNER_WALLET=owner
BT_VALIDATOR_WALLET=validator
BT_MINER_WALLET=miner
BT_DEFAULT_HOTKEY=default

# ── AgentKit (optional) ──────────────────────────────────
# Required only if running agent_action mandate types
# Get credentials from: https://portal.cdp.coinbase.com
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=

# ── Miner Config ─────────────────────────────────────────
# Axon port for miner (default: 8091)
MINER_AXON_PORT=8091

# Maximum blocks a miner will look back for state queries
MINER_MAX_BLOCK_LOOKBACK=1000

# ── Validator Config ─────────────────────────────────────
# Axon port for validator (default: 8092)
VALIDATOR_AXON_PORT=8092

# Timeout for miner responses (seconds)
VALIDATOR_TIMEOUT=30

# Weight-setting cadence (blocks). Default: 360 (~72 minutes at 12s/block)
VALIDATOR_TEMPO=360

# ── P5 Stewardship ───────────────────────────────────────
# Energy provenance declaration for carbon-aware scoring modifier
# Options: "renewable_verified" | "renewable_claimed" | "unknown" | "high_carbon"
ARCTURA_ENERGY_TAG=unknown

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
